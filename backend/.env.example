# Server listening port
PORT=5000

# Google Gemini API credentials (Required for AI extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model configuration (Defaults to gemini-2.5-flash if blank)
GEMINI_MODEL=gemini-2.5-flash

# Size of lead batches sent to the LLM (Reduce if experiencing token size issues)
BATCH_SIZE=25
